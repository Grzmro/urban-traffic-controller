\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Problem size: evaluation rate and per-evaluation cost as the city grows from 9 to 1024 intersections. The cost per evaluation rises sub-quadratically with city size, so larger cities remain tractable on the same worker pool.}}{9}{figure.caption.14}\protected@file@percent }
\newlabel{fig:size}{{4}{9}{Problem size: evaluation rate and per-evaluation cost as the city grows from 9 to 1024 intersections. The cost per evaluation rises sub-quadratically with city size, so larger cities remain tractable on the same worker pool}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {section}{\numberline {10}The interactive dashboard}{9}{section.10}\protected@file@percent }
\newlabel{sec:dashboard}{{10}{9}{The interactive dashboard}{section.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Network builder.} The left panel parametrises the city --- topology, junctions per side, lanes, edge length, demand intensity and the simulation horizon. Clicking \emph  {Build \& show network} generates the SUMO network and renders it. Here a $3\times 3$ grid with single-lane roads and a vehicle every \SI {1.6}{\second } is created.}}{10}{figure.caption.15}\protected@file@percent }
\newlabel{fig:shot-network}{{5}{10}{\textbf {Network builder.} The left panel parametrises the city --- topology, junctions per side, lanes, edge length, demand intensity and the simulation horizon. Clicking \emph {Build \& show network} generates the SUMO network and renders it. Here a $3\times 3$ grid with single-lane roads and a vehicle every \SI {1.6}{\second } is created}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Optimisation result.} The headline cards report baseline, optimised and improvement (\SI {-22.5}{\percent }). \emph  {Left:} the GA convergence curve --- total delay drops generation by generation and plateaus, indicating the search has converged. \emph  {Right:} the same before/after delay as bars.}}{10}{figure.caption.16}\protected@file@percent }
\newlabel{fig:shot-convergence}{{6}{10}{\textbf {Optimisation result.} The headline cards report baseline, optimised and improvement (\SI {-22.5}{\percent }). \emph {Left:} the GA convergence curve --- total delay drops generation by generation and plateaus, indicating the search has converged. \emph {Right:} the same before/after delay as bars}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \textbf  {Traffic animation.} The optimised plan is replayed: each dot is a vehicle, coloured by speed (green = moving, red = halting). A time slider scrubs through the simulated horizon, making queue formation and clearance visible directly.}}{11}{figure.caption.17}\protected@file@percent }
\newlabel{fig:shot-animation}{{7}{11}{\textbf {Traffic animation.} The optimised plan is replayed: each dot is a vehicle, coloured by speed (green = moving, red = halting). A time slider scrubs through the simulated horizon, making queue formation and clearance visible directly}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Congestion heatmap.} Baseline (left) versus optimised (right), with each intersection coloured by its average number of halting vehicles (green = clear, red = queued). The optimised network shows visibly fewer hot spots --- the same \SI {-22.5}{\percent } improvement, now localised in space.}}{11}{figure.caption.18}\protected@file@percent }
\newlabel{fig:shot-heatmap}{{8}{11}{\textbf {Congestion heatmap.} Baseline (left) versus optimised (right), with each intersection coloured by its average number of halting vehicles (green = clear, red = queued). The optimised network shows visibly fewer hot spots --- the same \SI {-22.5}{\percent } improvement, now localised in space}{figure.caption.18}{}}
