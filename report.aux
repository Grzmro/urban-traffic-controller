\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Final result of each algorithm on an equal evaluation budget ($8\times 8$ city, baseline $D=\SI {39473}{\veh \second }$). Lower delay is better.}}{4}{table.caption.4}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:compare}{{1}{4}{Final result of each algorithm on an equal evaluation budget ($8\times 8$ city, baseline $D=\SI {39473}{\veh \second }$). Lower delay is better}{table.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Algorithm comparison on equal budget. \emph  {Left:} convergence --- best total delay against the number of SUMO evaluations; the GA descends below every competitor. \emph  {Right:} final improvement over the fixed-time baseline. The GA reaches \SI {-27.3}{\percent }, hill climbing \SI {-19.7}{\percent }, while random search and simulated annealing stall near \SI {-8}{\percent }.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:compare}{{1}{5}{Algorithm comparison on equal budget. \emph {Left:} convergence --- best total delay against the number of SUMO evaluations; the GA descends below every competitor. \emph {Right:} final improvement over the fixed-time baseline. The GA reaches \SI {-27.3}{\percent }, hill climbing \SI {-19.7}{\percent }, while random search and simulated annealing stall near \SI {-8}{\percent }}{figure.caption.5}{}}
